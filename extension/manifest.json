{
  "manifest_version": 3,
  "name": "ADS LAB Collector — Ngajigaes",
  "version": "2.0.0",
  "description": "Capture LP URL dari Meta Ads Library GraphQL untuk ADS LAB.",
  "permissions": ["storage", "webRequest"],
  "host_permissions": [
    "https://www.facebook.com/*",
    "https://*.facebook.com/*",
    "https://*.supabase.co/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.facebook.com/ads/library*"],
      "js": ["funnelClassifier.js", "content.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["injected-fetch.js"],
      "matches": ["https://www.facebook.com/*", "https://*.facebook.com/*"]
    }
  ]
}
